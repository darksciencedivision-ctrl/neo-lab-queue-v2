$DBPort = $env:NEO_DB_PORT
if ([string]::IsNullOrWhiteSpace($DBPort)) { $DBPort = "55432" }

$DBName = $env:NEO_DB_NAME
if ([string]::IsNullOrWhiteSpace($DBName)) { $DBName = "neo_identity" }

$DBUser = $env:NEO_DB_USER
if ([string]::IsNullOrWhiteSpace($DBUser)) { $DBUser = "neo_user" }

$DBPass = $env:NEO_DB_PASS
if ([string]::IsNullOrWhiteSpace($DBPass)) { $DBPass = "neo_password_secure" }

$OdbcDriver = $env:NEO_ODBC_DRIVER
if ([string]::IsNullOrWhiteSpace($OdbcDriver)) { $OdbcDriver = "PostgreSQL ODBC Driver(UNICODE)" }

# Loop cadence
$CycleSleepSeconds = 5
$FailureBackoffSeconds = 3
$MaxBackoffSeconds = 30

