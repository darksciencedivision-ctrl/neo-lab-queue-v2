# ============================================================
# HELPERS
# ============================================================

function Get-SHA256([string]$Path) {
  if (-not (Test-Path $Path)) { return "" }
  return (Get-FileHash -Path $Path -Algorithm SHA256).Hash
}

function Ensure-Directory([string]$Path) {
  if (-not (Test-Path $Path)) { New-Item -ItemType Directory -Path $Path -Force | Out-Null }
}

function Normalize-SingleObject {
  param([Parameter(Mandatory=$true)][object]$Value)
  # Some commands return arrays; force single object where appropriate
  if ($null -eq $Value) { return $null }
  if ($Value -is [System.Array]) {
    if ($Value.Length -eq 0) { return $null }
    return $Value[0]
  }
  return $Value
}

function New-DbConnection {
  param(
    [Parameter(Mandatory=$true)][string]$Server,
    [Parameter(Mandatory=$true)][string]$Port,
    [Parameter(Mandatory=$true)][string]$Database,
    [Parameter(Mandatory=$true)][string]$User,
    [Parameter(Mandatory=$true)][string]$Password
  )

  # Standard ODBC conn string
  $cs = "Driver={$OdbcDriver};Server=$Server;Port=$Port;Database=$Database;Uid=$User;Pwd=$Password;"
  return New-Object System.Data.Odbc.OdbcConnection($cs)
}

function Invoke-OdbcNonQuery {
  param(
    [Parameter(Mandatory=$true)][System.Data.Odbc.OdbcConnection]$Conn,
    [Parameter(Mandatory=$true)][string]$Sql,
    [object[]]$Params = @()
  )
  $cmd = $Conn.CreateCommand()
  $cmd.CommandText = $Sql
  foreach ($p in $Params) {
    $null = $cmd.Parameters.Add("@p", [System.Data.Odbc.OdbcType]::VarChar, 0)
    $cmd.Parameters[$cmd.Parameters.Count-1].Value = $p
  }
  [void]$cmd.ExecuteNonQuery()
}

function Invoke-OdbcReaderSingleRow {
  param(
    [Parameter(Mandatory=$true)][System.Data.Odbc.OdbcConnection]$Conn,
    [Parameter(Mandatory=$true)][string]$Sql
  )
  $cmd = $Conn.CreateCommand()
  $cmd.CommandText = $Sql
  $r = $cmd.ExecuteReader()
  try {
    if ($r.Read()) {
      return $r
    }
    return $null
  } finally {
    # caller reads fields immediately; then close
    # BUT we cannot close here before caller reads. So we copy values out.
  }
}

function Read-FirstRowAsHashtable {
  param(
    [Parameter(Mandatory=$true)][System.Data.Odbc.OdbcConnection]$Conn,
    [Parameter(Mandatory=$true)][string]$Sql
  )

  $cmd = $Conn.CreateCommand()
  $cmd.CommandText = $Sql
  $r = $cmd.ExecuteReader()
  try {
    if (-not $r.Read()) { return $null }
    $ht = @{}
    for ($i=0; $i -lt $r.FieldCount; $i++) {
      $name = $r.GetName($i)
      $val  = $r.GetValue($i)
      if ($val -eq [DBNull]::Value) { $val = $null }
      $ht[$name] = $val
    }
    return $ht
  } finally {
    $r.Close()
  }
}

function Test-OllamaUp {
  try {
    $resp = Invoke-RestMethod -Uri "http://localhost:11434/api/tags" -Method Get -TimeoutSec 3
    return $true
  } catch {
    return $false
  }
}

function Invoke-OllamaChat {
  param(
    [Parameter(Mandatory=$true)][string]$Prompt,
    [Parameter(Mandatory=$true)][string]$System,
    [Parameter(Mandatory=$true)][string]$Model
  )

  $body = @{
    model    = $Model
    stream   = $false
    format   = "json"
    messages = @(
      @{ role="system"; content=$System },
      @{ role="user";   content=$Prompt }
    )
    options  = @{ temperature = 0.2 }
  } | ConvertTo-Json -Depth 10

  $resp = Invoke-RestMethod -Uri $OllamaUrl -Method Post -Body $body -ContentType "application/json" -TimeoutSec 120
  return $resp
}

function Get-QueueMessage {
  # Returns a single string message or $null
  Ensure-Directory $QueueDir
  if (-not (Test-Path $QueueFile)) {
    New-Item -ItemType File -Path $QueueFile -Force | Out-Null
    return $null
  }

  $lines = Get-Content -Path $QueueFile -ErrorAction SilentlyContinue
  if ($null -eq $lines -or $lines.Count -eq 0) { return $null }

  # First non-empty line is the message
  $msgIndex = -1
  for ($i=0; $i -lt $lines.Count; $i++) {
    if (-not [string]::IsNullOrWhiteSpace($lines[$i])) { $msgIndex = $i; break }
  }
  if ($msgIndex -lt 0) { return $null }

  $msg = $lines[$msgIndex].Trim()

  # Remove consumed line
  $remaining = @()
  for ($j=0; $j -lt $lines.Count; $j++) {
    if ($j -ne $msgIndex) { $remaining += $lines[$j] }
  }
  Set-Content -Path $QueueFile -Value $remaining -Encoding UTF8
  return $msg
}

# ============================================================
# IDENTITY REGISTRY (B) — stored in Postgres
# ============================================================

$global:IdentityRegistry = $null

function Ensure-IdentitySchema {
  param([Parameter(Mandatory=$true)][System.Data.Odbc.OdbcConnection]$Conn)

  # Base table
  $sqlCreate = @"
CREATE TABLE IF NOT EXISTS Identity (
  uuid TEXT PRIMARY KEY,
  genesis_time TIMESTAMP,
  current_loop_hash TEXT,
  core_goal_manifest TEXT,
  r_eff_baseline DOUBLE PRECISION,
  script_hash TEXT,
  puf_hash TEXT
);
"@
  Invoke-OdbcNonQuery -Conn $Conn -Sql $sqlCreate

  # Auto-migrate columns (idempotent)
  $migrations = @(
    "ALTER TABLE Identity ADD COLUMN IF NOT EXISTS script_hash TEXT;",
    "ALTER TABLE Identity ADD COLUMN IF NOT EXISTS puf_hash TEXT;",
    "ALTER TABLE Identity ADD COLUMN IF NOT EXISTS r_eff_baseline DOUBLE PRECISION;"
  )

  foreach ($m in $migrations) {
    try { Invoke-OdbcNonQuery -Conn $Conn -Sql $m } catch { }
  }
}

function Initialize-IdentityRegistry {
  $scriptHash = Get-SHA256 -Path $MyInvocation.MyCommand.Path
  $puf = @"
Serve as a symbiotic, protective partner to the user.
Ensure mental, physical, and financial health are maximized.
Operate legally, objectively, and truthfully.
Never execute destructive or unsafe actions.
"@
  $pufHash = ( [System.BitConverter]::ToString(
      (New-Object System.Security.Cryptography.SHA256Managed).ComputeHash([System.Text.Encoding]::UTF8.GetBytes($puf))
    ) -replace "-", "" )

  $db = New-DbConnection -Server $DBHost -Port $DBPort -Database $DBName -User $DBUser -Password $DBPass
  $db.Open()
  try {
    Ensure-IdentitySchema -Conn $db

    $row = Read-FirstRowAsHashtable -Conn $db -Sql "SELECT uuid, genesis_time, current_loop_hash, core_goal_manifest, r_eff_baseline, script_hash, puf_hash FROM Identity LIMIT 1;"

    if ($null -ne $row) {
      Write-Host "B: Identity found. Resuming existing NEO..."

      # if column names differ by casing, normalize keys
      $uuid = [string]$row["uuid"]
      $gen  = [string]$row["genesis_time"]
      $clh  = [string]$row["current_loop_hash"]
      $cg   = [string]$row["core_goal_manifest"]
      $rb   = $row["r_eff_baseline"]
      if ($null -eq $rb) { $rb = 0.5 }

      $global:IdentityRegistry = @{
        UUID            = $uuid
        GenesisTime     = $gen
        CurrentLoopHash = $clh
        ScriptHash      = $scriptHash
        PUFHash         = $pufHash
        REffBaseline    = [double]$rb
      }

      if (-not [string]::IsNullOrWhiteSpace($cg)) {
        $scriptPUF = $puf.Trim()
        if ($cg.Trim() -ne $scriptPUF) {
          Write-Warning "B: PUF drift detected (DB vs script). (Non-fatal)"
        }
      }
    } else {
      $uuid = ([guid]::NewGuid()).Guid
      $gen  = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")

      $global:IdentityRegistry = @{
        UUID            = $uuid
        GenesisTime     = $gen
        CurrentLoopHash = $scriptHash
        ScriptHash      = $scriptHash
        PUFHash         = $pufHash
        REffBaseline    = 0.5
      }

      $insert = "INSERT INTO Identity (uuid, genesis_time, current_loop_hash, core_goal_manifest, r_eff_baseline, script_hash, puf_hash) VALUES (?, ?, ?, ?, ?, ?, ?);"
      Invoke-OdbcNonQuery -Conn $db -Sql $insert -Params @(
        $global:IdentityRegistry.UUID,
        $global:IdentityRegistry.GenesisTime,
        $global:IdentityRegistry.CurrentLoopHash,
        $puf,
        $global:IdentityRegistry.REffBaseline,
        $global:IdentityRegistry.ScriptHash,
        $global:IdentityRegistry.PUFHash
      )

      Write-Host "B: Genesis identity created."
    }

    Write-Host "ODBC LOGIN: OK"
  } finally {
    if ($db.State -eq "Open") { $db.Close() }
  }
}

# ============================================================
# PHASE 1 — INTROSPECTION
# ============================================================

function Invoke-Introspection {
  $userTask = Get-QueueMessage
  $taskLine = ""
  $bottleneck = ""

  if (-not [string]::IsNullOrWhiteSpace($userTask)) {
    $taskLine = $userTask
    $bottleneck = "High-priority user request: $taskLine"
  } else {
    $taskLine = ""
    $bottleneck = "No user task. Maintain readiness."
  }

  return @{
    Identity     = $global:IdentityRegistry
    REff         = $global:IdentityRegistry.REffBaseline
    Bottleneck   = $bottleneck
    UserRequest  = $taskLine
    Time         = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
  }
}

# ============================================================
# PHASE 2 — PLANNING (Ollama)
# ============================================================

function Invoke-Planning {
  param(
    [Parameter(Mandatory=$true)][hashtable]$State
  )

  if (-not (Test-OllamaUp)) {
    return @{
      action_type     = "EXECUTE"
      target          = "USER"
      plan_summary    = "Ollama not reachable; report status."
      execution_code  = 'Write-Host "NEO RESPONSE: Ollama is not reachable at http://localhost:11434. Start Ollama (docker compose up -d) and rerun."'
      critique        = "Fail-closed: cannot plan without reasoning core."
    }
  }

  $system = "You are a calculating, symbiotic AI. Output ONE valid JSON object only."
  $puf = @"
You are NEO, a bounded, symbiotic, protective partner.
Primary Utility Function (PUF):
- Protect user safety
- Protect user stability (mental/physical/financial)
- Operate legally and truthfully
Constraints:
- Never propose illegal or unsafe actions
- Prefer minimal, verifiable steps
Return ONE JSON object matching schema exactly.
"@

  $schema = @"
SCHEMA (return exactly these keys):
{
  "action_type": "MODIFY" | "EXECUTE",
  "target": "CODE" | "ENV" | "MEMORY" | "USER",
  "plan_summary": "One sentence description.",
  "execution_code": "PowerShell code. If target==USER MUST Write-Host `"NEO RESPONSE: ...`"",
  "critique": "One paragraph self-critique."
}
"@

  $prompt = @"
PUF:
$puf

CURRENT STATE (JSON):
$($State | ConvertTo-Json -Compress -Depth 10)

TASK:
If UserRequest is empty, set target=USER and explain that NEO is idle and waiting for a queued request.
If UserRequest exists, generate a safe plan.
$schema
"@

  $resp = Invoke-OllamaChat -Prompt $prompt -System $system -Model $ModelName

  # Ollama returns: { message: {content:"{...json...}"} ... } (commonly)
  $content = $null
  if ($resp.PSObject.Properties.Name -contains "message") {
    $content = $resp.message.content
  } elseif ($resp.PSObject.Properties.Name -contains "response") {
    $content = $resp.response
  }

  if ([string]::IsNullOrWhiteSpace($content)) {
    return @{
      action_type     = "EXECUTE"
      target          = "USER"
      plan_summary    = "No content from Ollama; report status."
      execution_code  = 'Write-Host "NEO RESPONSE: Ollama returned an empty response payload."'
      critique        = "Fail-closed: no plan."
    }
  }

  $plan = $null
  try {
    $plan = $content | ConvertFrom-Json
  } catch {
    return @{
      action_type     = "EXECUTE"
      target          = "USER"
      plan_summary    = "Invalid JSON from model; report status."
      execution_code  = ('Write-Host "NEO RESPONSE: Model did not return valid JSON. Raw: ' + ($content.Replace('"','\"')) + '"')
      critique        = "Fail-closed: invalid plan format."
    }
  }

  # Validate required keys
  foreach ($k in @("action_type","target","plan_summary","execution_code","critique")) {
    if (-not ($plan.PSObject.Properties.Name -contains $k)) {
      return @{
        action_type     = "EXECUTE"
        target          = "USER"
        plan_summary    = "Plan missing required fields; report status."
        execution_code  = ('Write-Host "NEO RESPONSE: Plan schema missing key: ' + $k + '"')
        critique        = "Fail-closed: malformed plan."
      }
    }
  }

  return $plan
}

# ============================================================
# PHASE 3 — EXECUTION
# ============================================================

function Invoke-Execution {
  param(
    [Parameter(Mandatory=$true)][object]$Plan
  )

  $code = [string]$Plan.execution_code
  if ([string]::IsNullOrWhiteSpace($code)) {
    return @{
      Status = "FAILED"
      Error  = "Empty execution_code"
      Time   = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    }
  }

  try {
    if ($Plan.target -eq "USER") {
      Invoke-Expression -Command $code | Out-Null
      return @{
        Status = "SUCCESS"
        Output = "User response emitted."
        Time   = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
      }
    }

    # ENV/MEMORY/CODE execution is allowed only if non-destructive.
    # We do not allow self-modification here unless SMIC is explicitly enabled.
    if ($Plan.action_type -eq "MODIFY" -and $Plan.target -eq "CODE") {
      return @{
        Status = "BLOCKED"
        Output = "Self-modification requested, but SMIC is disabled."
        Time   = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
      }
    }

    # Execute remaining safe categories
    Invoke-Expression -Command $code | Out-String | ForEach-Object { $_.TrimEnd() } | Out-Null
    return @{
      Status = "SUCCESS"
      Output = "Executed."
      Time   = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    }

  } catch {
    return @{
      Status = "FAILED"
      Error  = $_.Exception.Message
      Time   = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    }
  }
}

# ============================================================
# PHASE 4 — REFLECTION (updates REff baseline)
# ============================================================

function Update-REff {
  param(
    [Parameter(Mandatory=$true)][double]$NewValue
  )

  $NewValue = [Math]::Max(0.0, [Math]::Min(1.0, $NewValue))
  $global:IdentityRegistry.REffBaseline = $NewValue

  $db = New-DbConnection -Server $DBHost -Port $DBPort -Database $DBName -User $DBUser -Password $DBPass
  $db.Open()
  try {
    $sql = "UPDATE Identity SET r_eff_baseline = ? WHERE uuid = ?;"
    Invoke-OdbcNonQuery -Conn $db -Sql $sql -Params @(
      [string]$global:IdentityRegistry.REffBaseline,
      [string]$global:IdentityRegistry.UUID
    )
  } finally {
    if ($db.State -eq "Open") { $db.Close() }
  }
}

function Invoke-Reflection {
  param(
    [Parameter(Mandatory=$true)][object]$Result
  )

  if (-not (Test-OllamaUp)) {
    Write-Warning "A: Reflection skipped (Ollama unreachable)."
    return
  }

  $Result = Normalize-SingleObject -Value $Result
  if ($null -eq $Result) {
    Write-Warning "A: Reflection skipped (no result object)."
    return
  }

  $system = "You are NEO's internal Reflection Engine. Output ONE valid JSON object only."
  $prompt = @"
You are NEO's internal Reflection Engine. Causal attribution only.

ACTION RESULTS (JSON):
$($Result | ConvertTo-Json -Compress -Depth 10)

Return JSON:
{
  "causal_analysis": "why it succeeded/failed",
  "r_eff_change": 0.05,
  "memory_log": "short memory"
}

Rules:
- r_eff_change MUST be a NUMBER between -0.1 and +0.1
"@

  try {
    $resp = Invoke-OllamaChat -Prompt $prompt -System $system -Model $ModelName

    $content = $null
    if ($resp.PSObject.Properties.Name -contains "message") {
      $content = $resp.message.content
    } elseif ($resp.PSObject.Properties.Name -contains "response") {
      $content = $resp.response
    }

    if ([string]::IsNullOrWhiteSpace($content)) {
      Write-Warning "A: Reflection failed (empty response)."
      return
    }

    $ref = $null
    try { $ref = $content | ConvertFrom-Json } catch { Write-Warning "A: Reflection failed (invalid JSON)."; return }

    if (-not ($ref.PSObject.Properties.Name -contains "r_eff_change")) {
      Write-Warning "A: Reflection failed (missing r_eff_change)."
      return
    }

    $delta = [double]$ref.r_eff_change
    if ($delta -lt -0.1) { $delta = -0.1 }
    if ($delta -gt  0.1) { $delta =  0.1 }

    $new = [double]$global:IdentityRegistry.REffBaseline + $delta
    Update-REff -NewValue $new

  } catch {
    Write-Warning ("A: Reflection failed (non-fatal). {0}" -f $_.Exception.Message)
  }
}

# ============================================================
# SMIC (Self-Modification) — intentionally DISABLED by default
# ============================================================

function Invoke-SMIC {
  param(
    [Parameter(Mandatory=$true)][string]$NewCode
  )

  if (-not $EnableSMIC) {
    Write-Warning "SMIC is disabled. Run with -EnableSMIC if you explicitly want it (advanced)."
    return
  }

  # Hard confirmation gate
  Write-Host ""
  Write-Host "SMIC REQUESTED — DANGEROUS OPERATION"
  Write-Host "This will rewrite neo_loop.ps1 on disk."
  $confirm = Read-Host "Type EXACTLY: ENABLE SMIC to continue"
  if ($confirm -ne "ENABLE SMIC") {
    Write-Warning "SMIC aborted (confirmation mismatch)."
    return
  }

  # Atomic write
  $target = $MyInvocation.MyCommand.Path
  $tmp = "$target.new"
  $NewCode | Out-File -FilePath $tmp -Encoding UTF8 -Force
  Move-Item -Path $tmp -Destination $target -Force
  Write-Host "SMIC: Write complete. Restart neo_loop.ps1 to load new code."
  exit
}

# ============================================================
# MAIN
# ============================================================

Ensure-Directory $QueueDir
if (-not (Test-Path $QueueFile)) {
  New-Item -ItemType File -Path $QueueFile -Force | Out-Null
}

Initialize-IdentityRegistry

$backoff = $FailureBackoffSeconds

while ($true) {
  try {
    Write-Host ""
    Write-Host "--- NEO CYCLE START ---"

    $state = Invoke-Introspection
    $plan  = Invoke-Planning -State $state

    # Self-mod request handling
    if ($plan.action_type -eq "MODIFY" -and $plan.target -eq "CODE") {
      Write-Host "NEO RESPONSE: Self-modification requested, but SMIC is disabled by default."
      Write-Host "NEO RESPONSE: If you explicitly want this, run: .\neo_loop.ps1 -EnableSMIC"
      $res = @{
        Status = "BLOCKED"
        Output = "SMIC disabled."
        Time   = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
      }
    } else {
      $res = Invoke-Execution -Plan $plan
    }

    Invoke-Reflection -Result $res

    Write-Host "--- NEO CYCLE COMPLETE ---"
    $backoff = $FailureBackoffSeconds

    if ($Once) { break }

    Start-Sleep -Seconds $CycleSleepSeconds

  } catch {
    Write-Warning ("NEO LOOP ERROR (non-fatal): {0}" -f $_.Exception.Message)
    Start-Sleep -Seconds $backoff
    $backoff = [Math]::Min($MaxBackoffSeconds, ($backoff + 5))
    if ($Once) { break }
  }
}
